                "UIHint": "Button"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "RaysPerFramePT",
            "comment": "The number of rays rendered per pixel per frame",
            "type": "Int",
            "dflt": "16",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "NumBouncesPT",
            "comment": "The maximum number of bounces a ray can have",
            "type": "Int",
            "dflt": "10",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "RRMinBouncesRT",
            "comment": "The number of bounces before russian roulette starts",
            "type": "Int",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "MipLevelPT",
            "comment": "The mip level textures are read at",
            "type": "Int",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "RayPosNormalNudgePT",
            "comment": "Intersection points are moved this much along the surface normal to avoid intersecting the same surface again",
            "type": "Float",
            "dflt": "0.01f",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "DirectLightingMultiplier",
            "comment": "A multiplier for direct lighting",
            "type": "Float",
            "dflt": "0.0f",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            }
        },
        {
            "name": "DirectLightCountPT",
            "comment": "How many direct lights to evaluate each ray, for next event estimation",
            "type": "Int",
            "dflt": "1",
            "visibility": "User",
            "onUserChange": {
                "name": "ResetPT"
            },
            "UIGroup": "PathTracing"
        },
        {
            "name": "ExposureFStops",
            "comment": "+1 doubles the brightness, -1 halves the brightness, and so on",
            "type": "Float",
            "visibility": "User",
            "UIGroup": "Tonemapping"
        },
        {
            "name": "ToneMapper",
            "comment": "The tone mapper to use to convert from HDR to SDR",
            "type": "Int",
            "dflt": "None",
            "visibility": "User",
            "Enum": "ToneMappingOperation",
            "UIGroup": "Tonemapping"
        }
    ],
    "shaders": [
        {
            "name": "ModelViewerVS",
            "fileName": "ModelViewerVS.hlsl",
            "type": "Vertex",
            "entryPoint": "vsmain"
        },
        {
            "name": "ModelViewerPS",
            "fileName": "ModelViewerPS.hlsl",
            "type": "Pixel",
            "entryPoint": "psmain",
            "resources": [
                {
                    "name": "DiffuseIBL",
