            "type": "Float",
            "dflt": "10.0f",
            "visibility": "User",
            "UIGroup": "IBL"
        },
        {
            "name": "SkyboxFaceSize",
            "comment": "The skybox is a cube map with 6 faces. This is the width and height of one face.",
