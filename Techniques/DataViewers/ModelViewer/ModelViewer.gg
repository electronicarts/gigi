    "structs": [
        {
            "name": "VB",
            "fields": [
                {
                    "name": "Position",
                    "type": "Float3",
                    "semantic": "Position"
                },
                {
                    "name": "Color",
                    "type": "Float3",
                    "semantic": "Color"
                },
                {
                    "name": "Normal",
                    "type": "Float3",
                    "semantic": "Normal"
                },
                {
                    "name": "Tangent",
                    "type": "Float4",
                    "semantic": "Tangent"
                },
                {
                    "name": "UV0",
                    "type": "Float2",
                    "semantic": "UV"
                },
                {
                    "name": "UV1",
                    "type": "Float2",
                    "semantic": "UV",
                    "semanticIndex": 1
                },
                {
                    "name": "UV2",
                    "type": "Float2",
                    "semantic": "UV",
                    "semanticIndex": 2
                },
                {
                    "name": "UV3",
                    "type": "Float2",
                    "semantic": "UV",
                    "semanticIndex": 3
                },
                {
                    "name": "MaterialID",
                    "type": "Int",
                    "semantic": "MaterialID"
